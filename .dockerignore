# ALLRENTZ Docker ignore file
# Optimize build context and security

# Git
.git
.gitignore
.gitattributes

# Documentation
README.md
CHANGELOG.md
LICENSE
docs/
*.md

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Operating System
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
coverage/
.nyc_output/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Test files
**/*.test.js
**/*.test.ts
**/*.test.tsx
**/*.spec.js
**/*.spec.ts
**/*.spec.tsx
test/
tests/
__tests__/
.coverage/
jest.config.*
vitest.config.*

# Linting and formatting
.eslintrc.*
.prettierrc.*
.prettierignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Logs
logs/
*.log

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Dependency directories
jspm_packages/

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env

# Serverless directories
.serverless

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Security files
*.pem
*.key
*.crt
*.p12

# Temporary files
tmp/
temp/
.tmp/

# Package lock files (use npm ci in Dockerfile)
package-lock.json
yarn.lock

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Storybook
.storybook/
storybook-static/

# Analytics and monitoring
.next/
.cache/
.parcel-cache/

# Local Netlify folder
.netlify

# Terraform
*.tfstate
*.tfstate.*
.terraform/

# Ansible
*.retry

# Secrets and sensitive files
secrets/
*.secret
*.private